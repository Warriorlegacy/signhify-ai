# ─── Required ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret-at-least-32-characters
MONGODB_URI=mongodb://localhost:27017/signhify

# ─── Server ──────────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=debug

# ─── Redis (optional, for caching and rate limiting) ────────────────
REDIS_URL=redis://localhost:6379

# ─── LLM Providers (at least one recommended) ───────────────────────
# Users can also provide their own keys via BYOK (Bring Your Own Key)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# System-level key for scheduled tasks (fallback)
SYSTEM_GEMINI_KEY=

# ─── Tools ───────────────────────────────────────────────────────────
TAVILY_API_KEY=
ELEVENLABS_API_KEY=

# ─── Gateways (optional) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ─── Observability (optional) ───────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=signhify-server
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Production overrides ────────────────────────────────────────────
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/signhify?retryWrites=true
# JWT_SECRET=<at-least-32-char-random-string>
# CORS_ORIGIN=https://your-frontend.vercel.app
# REDIS_URL=redis://your-redis-host:6379
