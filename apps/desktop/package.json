{
  "name": "signhify-desktop",
  "version": "1.0.0",
  "description": "Signhify AI Desktop — Native AI coding assistant with multi-provider fallback",
  "main": "out/index.js",
  "author": "Signhify AI",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env ELECTRON_DEV=1 electron .",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "package:all": "npm run build && electron-builder -mwl"
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "cross-env": "^7.0.3",
    "@types/node": "^20.0.0"
  },
  "build": {
    "appId": "ai.signhify.desktop",
    "productName": "Signhify AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png",
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "signhify",
      "repo": "signhify-desktop"
    }
  }
}
